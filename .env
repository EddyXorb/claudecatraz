# UID of the host user who owns the bind-mounted claude-home dir (run: id -u)
DEV_UID=1000

# Build versions
UV_VERSION=0.10.11
CLANG_VERSION=20
RUST_VERSION=1.94.0
CONAN_VERSION=2.23.0
NODE_VERSION=22
CLAUDE_CODE_VERSION=latest

# Anthropic auth — set before first start, or pre-populate CLAUDE_HOME
ANTHROPIC_API_KEY=

# GitLab — optional, configures the official GitLab MCP server at startup
# Use a Project Access Token or Group Access Token with Developer role
# Scopes needed: api, read_repository, write_repository
GITLAB_URL=
GITLAB_TOKEN=

# Mount paths — override these per project
CLAUDE_HOME=./claude
PROJECT_DIR=./workspace


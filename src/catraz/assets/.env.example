# ─────────────────────────────────────────────────────────────────────────────
# .env — SECRETS and host-specific values. DO NOT commit (see .gitignore).
# Principle (docs/design/agentic-workflow §11.1): secrets belong ONLY here, never
# in the read-only config/ folder. Tokens go only to the authorized service — in
# particular the agent (claude-dev-env) holds NO GitLab token (R6).
# ─────────────────────────────────────────────────────────────────────────────

# UID of the host user who owns the bind-mounted dirs (run: id -u)
DEV_UID=1000

# ── Base image ───────────────────────────────────────────────────────────────
# empty → bundled default base; otherwise one of:
# BASE_IMAGE=ghcr.io/acme/devenv:1.4
# BASE_DOCKERFILE=./Dockerfile.dev

# Custom base instead of the bundled cpp/rust/python toolchain:
# BASE_IMAGE=ghcr.io/you/base:tag           # ready-made image (no build)
# BASE_DOCKERFILE=./docker/Dockerfile.base  # your own Dockerfile (relative to the project)
# BASE_CONTEXT=.                             # build context (default: the Dockerfile's dir)

# ── Claude-Layer build versions ──────────────────────────────────────────────
# Build args for the claude-layer (applied on top of EVERY base). Defaults as shown here;
# overridable to pin Node or the Claude Code CLI.
NODE_VERSION=22
CLAUDE_CODE_VERSION=latest

# ── Anthropic / Claude ───────────────────────────────────────────────────────
# Use a dedicated sandbox account, NOT your primary/org account (§3.2).
# Run modes: interactive → `catraz run` (drop-in claude) · daemon → `catraz up --remote`
AUTH_MODE=subscription            # subscription | api_key
# Note: subscription tokens refreshed in-session are NOT written back to the host.
# If auth breaks after a long pause, run `catraz sync` to re-import the credential.
CLAUDE_CREDENTIAL_SOURCE=~/.claude
# ANTHROPIC_API_KEY=              # only for api_key

# ── GitLab — Warden ──────────────────────────────────────────────────────────
# Tokens go ONLY to the Warden container, never to the agent (R6).
GITLAB_READ_TOKEN=                        # scopes: read_api, read_repository
GITLAB_WRITE_TOKEN=                       # scopes: api  (service account / Developer, §7)
# GitLab upstream URL (Warden forwards there; agent uses https://gitlab.com as the
# canonical remote URL for the git-insteadOf rewrite to gitlab-warden:8080).
GITLAB_URL=https://gitlab.com

# ── Agent runtime (advanced) ─────────────────────────────────────────────────
# Remote-control invocation tuning (rarely changed):
# CLAUDE_RC_SPAWN=same-dir
# CLAUDE_RC_DEBUG_FILE=
# CLAUDE_RC_EXTRA_ARGS=

# ── Warden policy ────────────────────────────────────────────────────────────
# SOURCE OF TRUTH for the values below is config/warden.toml (version-controlled,
# host-editable). The WARDEN_* vars here are OPTIONAL OVERRIDES: set one (non-empty)
# to override the toml for that single setting; leave it empty/unset to use warden.toml.
#
# allowed_projects: comma-separated FULL paths of concrete GitLab projects (R6).
# NO wildcards/globs/regex, NO partial or leaf names, NO group prefixes — each entry
# must be a complete project path from the namespace root. A group prefix would even
# block warden startup (reconcile treats every entry as a concrete project).
#   correct:   WARDEN_ALLOWED_PROJECTS=group/sub/proj-a,group/sub/proj-b
#   wrong:     group/*   ·   *-ci   ·   proj-a   ·   group/sub
# WARDEN_ALLOWED_PROJECTS=
# WARDEN_BRANCH_PREFIX=          # R2 branch prefix (toml default: claude/)
# WARDEN_MAX_OPEN_MRS=           # R5
# WARDEN_MAX_OPEN_BRANCHES=      # R5
# WARDEN_MAX_WRITES_PER_HOUR=    # R5
#
# Warden: host path to warden.toml (bind-mounted read-only; default: ./config/warden.toml).
# WARDEN_CONFIG=./config/warden.toml


# ─────────────────────────────────────────────────────────────────────────────
# .env — SECRETS and host-specific values. DO NOT commit (see .gitignore).
# Principle (docs/design/agentic-workflow §11.1): secrets belong ONLY here, never
# in the read-only config/ folder. Tokens go only to the authorized service — in
# particular the agent (claude-dev-env) holds NO GitLab token (R6).
# ─────────────────────────────────────────────────────────────────────────────

# UID of the host user who owns the bind-mounted dirs (run: id -u)
DEV_UID=1000

# Build versions
UV_VERSION=0.10.11
CLANG_VERSION=20
RUST_VERSION=1.94.0
CONAN_VERSION=2.23.0
NODE_VERSION=22
CLAUDE_CODE_VERSION=latest

# ── Anthropic / Claude ───────────────────────────────────────────────────────
# Use a dedicated sandbox account, NOT your primary/org account (§3.2).
# Set before first start, or pre-populate CLAUDE_HOME via `python3 entrypoint.py sync`.
ANTHROPIC_API_KEY=

# ── Compose profiles ─────────────────────────────────────────────────────────
# Stage 01 (bootstrap hardening): the GitLab MCP sidecar is inert without an agent
# token (R6) and is replaced by the Warden in stage 02. Default is therefore empty.
# GitHub is out of scope for now.
#   empty  → claude-dev-env only
COMPOSE_PROFILES=

# ── GitLab — stage 02 (Warden) ───────────────────────────────────────────────
# NOT set in stage 01: no GitLab token in the agent (R6). The tokens below go
# exclusively to the Warden container (docs/design/agentic-workflow §11.3), not the
# agent. Commented out until stage 02 (Warden) is in place.
# GITLAB_READ_TOKEN=      # scopes: read_api, read_repository
# GITLAB_WRITE_TOKEN=     # scopes: api  (service account / Developer, §7)

# ── Mount paths (bind-mounts next to the compose file, §11.2) ────────────────
CLAUDE_HOME=./claude
PROJECT_DIR=./workspace

# ─────────────────────────────────────────────────────────────────────────────
# .env — SECRETS and host-specific values. DO NOT commit (see .gitignore).
# Principle (docs/design/agentic-workflow §11.1): secrets belong ONLY here, never
# in the read-only config/ folder. Tokens go only to the authorized service — in
# particular the agent (claude-dev-env) holds NO GitLab token (R6).
# ─────────────────────────────────────────────────────────────────────────────

# UID of the host user who owns the bind-mounted dirs (run: id -u)
DEV_UID=1000

# Build versions
UV_VERSION=0.10.11
CLANG_VERSION=20
RUST_VERSION=1.94.0
CONAN_VERSION=2.23.0
NODE_VERSION=22
CLAUDE_CODE_VERSION=latest

# ── Anthropic / Claude ───────────────────────────────────────────────────────
# Use a dedicated sandbox account, NOT your primary/org account (§3.2).
# Set before first start, or pre-populate CLAUDE_HOME via `python3 entrypoint.py sync`.
ANTHROPIC_API_KEY=

# ── GitLab — Warden ──────────────────────────────────────────────────────────
# Tokens gehen NUR zum Warden-Container, nie zum Agent (R6).
GITLAB_READ_TOKEN=                        # scopes: read_api, read_repository
GITLAB_WRITE_TOKEN=                       # scopes: api  (service account / Developer, §7)
# GitLab upstream URL (Warden leitet dorthin weiter; Agent nutzt https://gitlab.com als
# kanonische Remote-URL fuer den git-insteadOf-Rewrite auf gitlab-warden:8080).
GITLAB_URL=https://gitlab.com

# ── Compose profiles ─────────────────────────────────────────────────────────
# warden = gitlab-warden-Service aktiv (Stufe 02); ohne warden kein GitLab-Zugriff.
COMPOSE_PROFILES=warden

# Warden: comma-separated GitLab project paths the agent is allowed to push to (R2/R5).
# WARDEN_ALLOWED_PROJECTS=group/project
#
# Warden: prefix enforced on agent-created branches (R5, default: claude/).
# WARDEN_BRANCH_PREFIX=claude/
#
# Warden: host path to warden.toml (bind-mounted read-only; default: ./config/warden.toml).
# WARDEN_CONFIG=./config/warden.toml

# ── Mount paths (bind-mounts next to the compose file, §11.2) ────────────────
CLAUDE_HOME=./claude
PROJECT_DIR=./workspace

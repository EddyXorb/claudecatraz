# UID of the host user who owns the bind-mounted claude-home dir (run: id -u)
DEV_UID=1000

# Build versions
UV_VERSION=0.10.11
CLANG_VERSION=20
RUST_VERSION=1.94.0
CONAN_VERSION=2.23.0
NODE_VERSION=22
CLAUDE_CODE_VERSION=latest

# Anthropic auth — set before first start, or pre-populate CLAUDE_HOME
ANTHROPIC_API_KEY=

# GitLab — optional. Set COMPOSE_PROFILES=gitlab to activate the MCP sidecar.
# Without it, only claude-dev-env starts and GitLab access is unavailable.
COMPOSE_PROFILES=gitlab

# GitLab MCP sidecar — optional. 
# GITLAB_API_URL: instance root + /api/v4 (not a project path)
# GITLAB_API_TOKEN: Group Access Token, scopes: api
GITLAB_API_URL=https://gitlab.com/api/v4
GITLAB_API_TOKEN=
GITLAB_READ_ONLY_MODE=true

# GitHub MCP sidecar — optional. Add COMPOSE_PROFILES=gitlab,github (or just github).
# GITHUB_TOKEN: Personal Access Token or Fine-Grained Token; only visible to github-mcp.
# GITHUB_TOKEN=ghp_...

# Mount paths — override these per project
CLAUDE_HOME=./claude
PROJECT_DIR=./workspace


# Claude auth tokens and MCP config — never commit
claude-home/

# Local project workspace
workspace*
.claude
# Root-level scratch dir only (a historical local --agent-home test target) —
# anchored so it doesn't shadow src/catraz/assets/agents/claude/ (§06-migration.md
# Schritt 7: the claude agent adapter's real source directory).
/claude
.mypy_cache
.ruff_cache
.venv
.pytest_cache
# Secrets
.env
# Local env overrides
.env.local

# Forward-Proxy runtime audit logs — keep the dir, ignore the contents
/logs/squid/*
!/logs/squid/.gitkeep
# Runtime state & logs (Bind-Mounts neben dem Compose-File, §11.2/§11.6) —
# Laufzeitdaten, nicht versionieren. config/ wird BEWUSST versioniert (Policy-Artefakt).
state/
logs/

# Python
__pycache__/
*.pyc

.catraz/

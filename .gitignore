# Claude auth tokens and MCP config — never commit
claude-home/

# Local project workspace
workspace*
.claude
claude

# Secrets
.env
# Local env overrides
.env.local

claude

# Forward-Proxy runtime audit logs — keep the dir, ignore the contents
/logs/squid/*
!/logs/squid/.gitkeep
# Runtime state & logs (Bind-Mounts neben dem Compose-File, §11.2/§11.6) —
# Laufzeitdaten, nicht versionieren. config/ wird BEWUSST versioniert (Policy-Artefakt).
state/
logs/

# Python
__pycache__/
*.pyc
